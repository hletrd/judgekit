FROM ubuntu:24.10
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates && \
    curl -fsSL https://github.com/uiua-lang/uiua/releases/latest/download/uiua-x86_64-unknown-linux-gnu.tar.gz | tar xz -C /usr/local/bin && \
    rm -rf /var/lib/apt/lists/* && \
    useradd -m -s /bin/false judge && mkdir -p /workspace && chown judge:judge /workspace
WORKDIR /workspace
USER judge
