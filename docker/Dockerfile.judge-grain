FROM ghcr.io/grain-lang/grain:0.7.2-slim AS grain-src

FROM debian:bookworm-slim
COPY --from=grain-src /usr/local/bin/grain /usr/local/bin/grain
RUN chmod +x /usr/local/bin/grain && \
    useradd --no-create-home --shell /usr/sbin/nologin judge && \
    mkdir -p /workspace && chown judge:judge /workspace

WORKDIR /workspace
USER judge
